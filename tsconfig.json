{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@motion-canvas/2d/lib",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*", "vite.config.ts"]
}
